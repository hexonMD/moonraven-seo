# Shopify Storefront integration for Moonraven SEO frontend
# Copy to .env.local and fill in the real values. .env.local is gitignored.

# myshopify.com domain (no protocol, no trailing slash)
SHOPIFY_STORE_DOMAIN=moonraven.myshopify.com

# Public-facing shop URL — used for "View on store" / cart hand-off links
NEXT_PUBLIC_SHOP_URL=https://shop.moonraven.com

# Dev Dashboard app credentials — used server-side to mint short-lived (24h)
# Admin API access tokens via the client_credentials grant. The minted token
# is cached in-process and auto-refreshed before expiry.
SHOPIFY_APP_CLIENT_ID=
SHOPIFY_APP_CLIENT_SECRET=

# Shopify Admin API version (advance only when we've reviewed the changelog)
SHOPIFY_API_VERSION=2025-07

# Public site URL — used in sitemap, robots, canonical tags
NEXT_PUBLIC_SITE_URL=https://moonraven.com
